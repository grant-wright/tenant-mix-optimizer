# ─────────────────────────────────────────────
# Tenant Mix Optimizer — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# MongoDB Atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER.mongodb.net/
MONGODB_DB=tenant_mix

# Google Cloud
GCP_PROJECT_ID=rapid-agent-tenant-mix
GCP_REGION=australia-southeast1

# Gemini / Vertex AI (uses Application Default Credentials in prod)
# Leave blank if using ADC; set for local dev with a service account key path
GOOGLE_APPLICATION_CREDENTIALS=

# Agent Builder
AGENT_ID=
AGENT_LOCATION=global
